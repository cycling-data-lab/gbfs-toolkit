    { "type": "docs", "section": "Documentation" },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "ci", "section": "Tests", "hidden": true },
    { "type": "build", "section": "Tests", "hidden": true },
    { "type": "chore", "section": "Tests", "hidden": true }
  ]
}
